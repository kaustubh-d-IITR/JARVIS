# Spotify Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8501/callback

# Deepgram API Key (Voice transcription)
# Get this from https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq API Key (LLM)
# Get this from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# OpenWeather API Key (Weather Context)
# Get this from https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key
